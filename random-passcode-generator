<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Random Passcode Generator</title>

  <style>
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f7f7fb;
      color: #1f2937;
      margin: 0;
      padding: 40px 20px;
    }

    main {
      max-width: 520px;
      margin: 0 auto;
      background: white;
      padding: 28px;
      border-radius: 18px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      text-align: center;
    }

    h1 {
      margin-top: 0;
    }

    .note {
      color: #6b7280;
      margin-bottom: 24px;
    }

    #passcode {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      background: #f3f4f6;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 18px;
      margin: 20px 0;
      word-break: break-all;
    }

    button {
      background: #2563eb;
      color: white;
      border: none;
      padding: 12px 18px;
      border-radius: 999px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      margin: 6px;
    }

    button:hover,
    button:focus {
      background: #1d4ed8;
      outline: 3px solid rgba(37, 99, 235, 0.25);
      outline-offset: 3px;
    }

    .message {
      margin-top: 14px;
      color: #047857;
      font-weight: 700;
      min-height: 1.4em;
    }
  </style>
</head>

<body>
  <main>
    <h1>Random Passcode Generator</h1>

    <p class="note">
      Generates a random 6-character alphanumeric passcode using uppercase letters, lowercase letters, and numbers.
    </p>

    <div id="passcode" aria-live="polite">------</div>

    <button id="generateButton">Generate passcode</button>
    <button id="copyButton">Copy passcode</button>

    <div id="message" class="message" aria-live="polite"></div>
  </main>

  <script>
    const characters = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";

    const passcodeDisplay = document.getElementById("passcode");
    const generateButton = document.getElementById("generateButton");
    const copyButton = document.getElementById("copyButton");
    const message = document.getElementById("message");

    generateButton.addEventListener("click", () => {
      const passcode = generatePasscode(6);
      passcodeDisplay.textContent = passcode;
      message.textContent = "";
    });

    copyButton.addEventListener("click", async () => {
      const passcode = passcodeDisplay.textContent;

      if (passcode === "------") {
        message.textContent = "Generate a passcode first.";
        return;
      }

      await navigator.clipboard.writeText(passcode);
      message.textContent = "Passcode copied.";
    });

    function generatePasscode(length) {
      const randomValues = new Uint32Array(length);
      crypto.getRandomValues(randomValues);

      let passcode = "";

      for (let i = 0; i < length; i++) {
        const randomIndex = randomValues[i] % characters.length;
        passcode += characters[randomIndex];
      }

      return passcode;
    }
  </script>
</body>
</html>
